# ============ L'usine — configuration ============

# Port d'écoute (défaut : 3200)
PORT=3200

# Clé de chiffrement des secrets (64 caractères hex).
# Générée automatiquement au premier lancement si absente (stockée dans data/encryption.key).
# ⚠️ Ne la change JAMAIS après coup : les credentials existants deviendraient illisibles.
# ENCRYPTION_KEY=

# Secret de signature des sessions (généré automatiquement si absent).
# SESSION_SECRET=
